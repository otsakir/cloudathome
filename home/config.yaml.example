# CloudAtHome home-side configuration
# Generated by: python scripts/register_home.py
# Copy to config.yaml and fill in real values, or run register_home.py to generate automatically.
# Override the config file location with the HOME_CONFIG environment variable.

cloudlink:
  # Base URL of the cloud server (no trailing slash)
  cloudserver_url: https://cloud.example.com

  # API authentication token (obtained from the cloud server on registration)
  auth_token: your-token-here

  # Unique slug identifying this home on the cloud server
  home_slug: your-home-slug-here

  ssh:
    # Hostname of the cloud server (usually the same host as cloudserver_url)
    host: cloud.example.com
    # SSH port on the cloud server (8022 for the Docker dev stack; 22 in production)
    port: 8022
    # SSH username assigned by the cloud server during home registration
    username: home03_alice
    # Absolute path to the private key generated by scripts/generate_keys.py
    private_key_path: /home/alice/.ssh/cloudathome_ed25519

  ports:
    # First tunnel port allocated to this home on the cloud server
    base: 2300
    # Number of tunnel ports available (one per proxy entry)
    count: 10

  tcp_ports:
    # First public TCP port allocated to this home on the cloud server
    base: 10300
    # Number of public TCP ports available (one per TCP forward)
    count: 10

# Path to the SQLite database file.
# Relative paths are resolved against this config file's directory.
# Default when omitted: db.sqlite3 (alongside config.yaml)
database: db.sqlite3

# certbot:
#   # Optional: copy issued certificates to this directory after issuance.
#   # Certificates are placed under <deploy_path>/<domain>/{fullchain,privkey,chain,cert}.pem
#   deploy_path: /etc/nginx/certs

# features:
#   # Allow proxy entries to forward to hosts other than localhost on the home network.
#   # Disabled by default; set to true to expose the home_host field when adding a proxy entry.
#   lan_forwarding: false
