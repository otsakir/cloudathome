# Copy this to cloud.env and fill in the values.
# cloud.env is gitignored and must never be committed.

# Django secret key — generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=changeme

# The public domain name for the cloud server itself (e.g. cloud.example.com).
# Used for ALLOWED_HOSTS, CSRF_TRUSTED_ORIGINS, and HAProxy SNI routing.
CLOUD_DOMAIN=cloud.example.com
